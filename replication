synchronous_standby_names='*' ##primary postgresql.conf

touch standby.signal
/usr/pgsql-18/bin/pg_basebackup -D /u01/pgsql/18 --checkpoint=fast -P -h 192.168.108.131
restore_command = 'scp 192.168.108.131:/u01/archivelogs/%f %p'
primary_conninfo = 'host=192.168.108.131 user=postgres password=postgres application_name=random' 


what -R in pg_basebackup does?
------------------------------
1. it will create standby.signal
2. it will write primary_conninfo

-- you have to manually write restore_command
-- if sync standby manually edit primary_conninfo




take backup and simply start
take backup and add recovery.signal+restore_command = apply archive logs as well
take backup and add recovery.signal+restore_command+recovery_target = PITR
take backup and add standby.signal+restore_command = physical standby (archive based)
take backup and add standby.signal+restore_command+primary_conninfo = physical standby (realtime apply)
take backup and add standby.signal+restore_command+primary_conninfo+application_name = synch. physical standby (realtime apply)





